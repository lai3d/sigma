{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ]},
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Retransmits",
      "type": "stat",
      "targets": [{
        "expr": "sum(sigma_tcp_retransmits_total{hostname=~\"$hostname\"})",
        "legendFormat": "retransmits"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 2000 }
          ]},
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Active Connections",
      "type": "stat",
      "targets": [{
        "expr": "sum(sigma_tcp_connections_active{hostname=~\"$hostname\"})",
        "legendFormat": "active"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]},
          "unit": "ops"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Retransmit Rate (5m)",
      "type": "stat",
      "targets": [{
        "expr": "sum(rate(sigma_tcp_retransmits_total{hostname=~\"$hostname\"}[5m]))",
        "legendFormat": "rate"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name" },
      "title": "Top Retransmitter",
      "type": "stat",
      "targets": [{
        "expr": "topk(1, sigma_tcp_retransmits_total{hostname=~\"$hostname\"})",
        "legendFormat": "{{ process }}"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "title": "Retransmits Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Retransmit Rate by Process",
      "type": "timeseries",
      "targets": [{
        "expr": "rate(sigma_tcp_retransmits_total{hostname=~\"$hostname\"}[5m])",
        "legendFormat": "{{ hostname }} / {{ process }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Total Retransmit Rate",
      "type": "timeseries",
      "targets": [{
        "expr": "sum by (hostname) (rate(sigma_tcp_retransmits_total{hostname=~\"$hostname\"}[5m]))",
        "legendFormat": "{{ hostname }}"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "title": "Connections",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Active Connections by Process",
      "type": "timeseries",
      "targets": [{
        "expr": "sigma_tcp_connections_active{hostname=~\"$hostname\"}",
        "legendFormat": "{{ hostname }} / {{ process }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "single" }
      },
      "title": "Connection Distribution",
      "type": "piechart",
      "targets": [{
        "expr": "sigma_tcp_connections_active{hostname=~\"$hostname\"}",
        "legendFormat": "{{ process }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "New Connections Rate",
      "type": "timeseries",
      "targets": [{
        "expr": "rate(sigma_tcp_connections_total{hostname=~\"$hostname\"}[5m])",
        "legendFormat": "{{ hostname }} / {{ process }}"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "title": "Process Details",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Process" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Container" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Hostname" }, "properties": [{ "id": "custom.width", "value": 150 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Active Conns" }] },
      "title": "Process Details",
      "type": "table",
      "targets": [
        {
          "expr": "sigma_tcp_connections_active{hostname=~\"$hostname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "sigma_tcp_connections_total{hostname=~\"$hostname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "sigma_tcp_retransmits_total{hostname=~\"$hostname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "process" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "process": "Process",
              "container 1": "Container",
              "hostname 1": "Hostname",
              "Value #A": "Active Conns",
              "Value #B": "Total Conns",
              "Value #C": "Retransmits"
            },
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "container 2": true,
              "container 3": true,
              "hostname 2": true,
              "hostname 3": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["sigma", "tcp", "ebpf"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Data Source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(sigma_tcp_retransmits_total, hostname)",
        "hide": 0,
        "includeAll": true,
        "label": "Hostname",
        "multi": true,
        "name": "hostname",
        "query": "label_values(sigma_tcp_retransmits_total, hostname)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Sigma TCP Health (eBPF)",
  "uid": "sigma-tcp-health"
}
